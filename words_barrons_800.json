    {word:"Benign",pos:"adjective",def:"Gentle and kind; not harmful.",bangla:"সৌম্য ও ক্ষতিকর নয়।",synonyms:["harmless","kindly","gentle"],antonyms:["malignant","harmful","dangerous"],examples:["The doctor assured her that the growth was benign.","His benign humor never offended anyone."]},
