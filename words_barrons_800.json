[
    {word:"Abase",pos:"verb",def:"To lower in rank, prestige, or esteem; to humiliate.",bangla:"অপমান করা বা মর্যাদা কমানো। কেউ যদি কাউকে সবার সামনে ছোট করেন, তিনি তাকে abase করছেন।",synonyms:["humiliate","degrade","demean"],antonyms:["honor","elevate","exalt"],examples:["He refused to abase himself before his enemies.","The dictator abase his opponents publicly to crush their spirits."]},
    {word:"Abash",pos:"verb",def:"To make someone feel embarrassed or ashamed.",bangla:"লজ্জিত বা বিব্রত করা। কারো ভুল সবার সামনে ধরিয়ে দিলে সে abash হয়।",synonyms:["embarrass","shame","disconcert"],antonyms:["embolden","reassure","encourage"],examples:["She was abashed by her careless mistake in front of the audience.","Nothing could abash the confident young speaker."]},
    {word:"Abdicate",pos:"verb",def:"To renounce one's throne or a position of power or responsibility.",bangla:"ক্ষমতা বা দায়িত্ব ছেড়ে দেওয়া। যেমন কোনো রাজা সিংহাসন ত্যাগ করলে তিনি abdicate করেন।",synonyms:["resign","relinquish","renounce"],antonyms:["assume","claim","retain"],examples:["The king abdicated his throne after years of controversial rule.","She abdicated her responsibilities as team leader during the crisis."]},
    {word:"Aberration",pos:"noun",def:"A departure from what is normal or expected; an anomaly.",bangla:"স্বাভাবিক থেকে বিচ্যুতি। একটি aberration হলো এমন কিছু যা সাধারণ নিয়মের বাইরে।",synonyms:["anomaly","deviation","irregularity"],antonyms:["norm","standard","regularity"],examples:["The warm January weather was an aberration in the region's climate.","His violent outburst was considered an aberration by those who knew him."]},
    {word:"Abeyance",pos:"noun",def:"A state of temporary suspension or inactivity.",bangla:"সাময়িক স্থগিতাবস্থা। কোনো কাজ বা পরিকল্পনা যদি কিছুদিনের জন্য থেমে থাকে, তাকে abeyance বলে।",synonyms:["suspension","dormancy","postponement"],antonyms:["continuance","resumption","activity"],examples:["The project was held in abeyance until new funding could be secured.","Legal proceedings were in abeyance pending further investigation."]}
  ],
  // SET 2
  [
    {word:"Abhor",pos:"verb",def:"To regard with disgust and hatred.",bangla:"ঘৃণা করা বা বিরক্ত হওয়া। কেউ যদি কোনো কিছুকে মনে প্রাণে ঘৃণা করেন, তিনি সেটাকে abhor করেন।",synonyms:["detest","loathe","despise"],antonyms:["love","admire","cherish"],examples:["She abhors any form of cruelty to animals.","He abhorred the thought of lying to his parents."]},
    {word:"Abjure",pos:"verb",def:"To solemnly renounce a belief or claim.",bangla:"দৃঢ়ভাবে কোনো বিশ্বাস বা দাবি ত্যাগ করা।",synonyms:["renounce","recant","forswear"],antonyms:["embrace","uphold","maintain"],examples:["The politician abjured his earlier statements under pressure.","She abjured her citizenship to live abroad freely."]},
    {word:"Abscond",pos:"verb",def:"To leave hurriedly and secretly, typically to avoid detection.",bangla:"গোপনে পালিয়ে যাওয়া। কোনো অপরাধী যদি পুলিশের নাগাল এড়াতে রাতারাতি পালিয়ে যায়, সে abscond করেছে।",synonyms:["flee","escape","bolt"],antonyms:["remain","stay","appear"],examples:["The cashier absconded with thousands of dollars from the safe.","He absconded from the prison during the night shift."]},
    {word:"Abstemious",pos:"adjective",def:"Not self-indulgent; restrained in eating and drinking.",bangla:"সংযমী বা মিতাহারী। যিনি খাওয়া-দাওয়ায় অতিরিক্ত ভোগ করেন না, তিনি abstemious।",synonyms:["temperate","moderate","frugal"],antonyms:["indulgent","excessive","gluttonous"],examples:["His abstemious lifestyle contributed to his remarkable health at ninety.","She was abstemious at the banquet, eating very little."]},
    {word:"Abstruse",pos:"adjective",def:"Difficult to understand; obscure.",bangla:"দুর্বোধ্য ও জটিল। এমন বিষয় যা সহজে বোঝা যায় না।",synonyms:["obscure","esoteric","recondite"],antonyms:["clear","simple","accessible"],examples:["The philosopher's abstruse arguments baffled even his colleagues.","The abstruse legal terminology confused the jury."]}
  ],
  // SET 3
  [
    {word:"Accolade",pos:"noun",def:"An award or privilege granted as a special honor.",bangla:"বিশেষ পুরস্কার বা স্বীকৃতি। কোনো শিল্পী বা বিজ্ঞানী যখন তাদের কাজের জন্য সম্মানিত হন, সেটাই accolade।",synonyms:["award","honor","tribute"],antonyms:["criticism","censure","condemnation"],examples:["The young novelist received numerous accolades for her debut novel.","Winning the Oscar was the ultimate accolade for the actress."]},
    {word:"Accost",pos:"verb",def:"To approach and address someone boldly or aggressively.",bangla:"হঠাৎ করে কাউকে থামিয়ে সম্বোধন করা, বিশেষত আগ্রাসীভাবে।",synonyms:["confront","approach","address"],antonyms:["avoid","ignore","evade"],examples:["A stranger accosted him on the street asking for directions.","The journalist accosted the politician with difficult questions."]},
    {word:"Acerbity",pos:"noun",def:"Sharpness or harshness of manner or speech.",bangla:"কথাবার্তায় কটুতা বা তীক্ষ্ণতা। কঠোর ও কটু মন্তব্যের গুণকে acerbity বলে।",synonyms:["harshness","sharpness","tartness"],antonyms:["mildness","gentleness","kindness"],examples:["His acerbity in the meeting alienated potential allies.","The critic's acerbity was legendary in literary circles."]},
    {word:"Acquiesce",pos:"verb",def:"To accept something reluctantly but without protest.",bangla:"অনিচ্ছায় কিন্তু নীরবে মেনে নেওয়া। প্রতিবাদ না করে মেনে নেওয়াই acquiesce।",synonyms:["comply","consent","concede"],antonyms:["resist","protest","refuse"],examples:["She acquiesced to her parents' wishes despite her own desires.","The board reluctantly acquiesced to the CEO's demands."]},
    {word:"Acrimony",pos:"noun",def:"Bitterness or ill feeling.",bangla:"তিক্ততা ও বিদ্বেষ। সম্পর্ক ভেঙে গেলে যে তিক্ততা থাকে, সেটাই acrimony।",synonyms:["bitterness","rancor","hostility"],antonyms:["goodwill","amity","friendliness"],examples:["The divorce was filled with acrimony and mutual accusations.","Years of acrimony between the two nations finally ended with a treaty."]}
  ],
  // SET 4
  [
    {word:"Adamant",pos:"adjective",def:"Refusing to be persuaded or to change one's mind.",bangla:"অনড় বা অটল। যিনি কিছুতেই মত পরিবর্তন করেন না, তিনি adamant।",synonyms:["resolute","inflexible","unyielding"],antonyms:["flexible","yielding","compliant"],examples:["She was adamant about not changing her decision.","Despite all arguments, he remained adamant in his refusal."]},
    {word:"Admonish",pos:"verb",def:"To warn or reprimand someone firmly.",bangla:"সতর্ক করা বা মৃদু ভর্ৎসনা করা। কেউ কোনো ভুল করলে তাকে সতর্ক করে দেওয়াই admonish।",synonyms:["reprimand","caution","rebuke"],antonyms:["praise","commend","approve"],examples:["The teacher admonished students for being late to class.","She admonished her friend for making reckless decisions."]},
    {word:"Adulterate",pos:"verb",def:"To make something impure by adding inferior substances.",bangla:"ভেজাল মেশানো। খাদ্যে বা পণ্যে নিম্নমানের উপাদান মিশিয়ে তা নষ্ট করাকে adulterate বলে।",synonyms:["contaminate","corrupt","dilute"],antonyms:["purify","refine","improve"],examples:["The company was fined for adulterating its olive oil with cheaper oils.","Unscrupulous merchants sometimes adulterate spices with artificial fillers."]},
    {word:"Adversity",pos:"noun",def:"Difficult or unfavorable circumstances; misfortune.",bangla:"বিপদ বা দুর্দশা। জীবনে যখন কঠিন পরিস্থিতি আসে, সেটাই adversity।",synonyms:["hardship","misfortune","difficulty"],antonyms:["prosperity","fortune","success"],examples:["He showed remarkable courage in the face of adversity.","Adversity can strengthen character if faced with resilience."]},
    {word:"Aesthetic",pos:"adjective",def:"Concerned with beauty or the appreciation of beauty.",bangla:"সৌন্দর্য সম্পর্কিত। শিল্পে বা জীবনে সুন্দরের প্রতি আগ্রহকে aesthetic বলা হয়।",synonyms:["artistic","tasteful","beautiful"],antonyms:["unattractive","ugly","unpleasant"],examples:["The architect had a keen aesthetic sense that defined his work.","She decorated her home with great aesthetic care."]}
  ],
  // SET 5
  [
    {word:"Affectation",pos:"noun",def:"Behavior or speech designed to impress others; pretense.",bangla:"কৃত্রিম আচরণ বা ভান করা। স্বাভাবিক না হয়ে অন্যকে মুগ্ধ করতে কৃত্রিম ভাব দেখানোকে affectation বলে।",synonyms:["pretense","artificiality","mannerism"],antonyms:["naturalness","sincerity","simplicity"],examples:["Her British accent was a mere affectation — she had grown up in Ohio.","His literary affectations irritated those who preferred plain speech."]},
    {word:"Aggrandize",pos:"verb",def:"To increase power or status, often exaggeratedly.",bangla:"নিজেকে অতিরিক্তভাবে বড় করা বা দেখানো।",synonyms:["exalt","magnify","inflate"],antonyms:["diminish","humble","minimize"],examples:["He constantly aggrandized his role in the project.","The leader sought to aggrandize the nation through military conquest."]},
    {word:"Alacrity",pos:"noun",def:"Brisk and cheerful readiness.",bangla:"উৎসাহী তৎপরতা। আগ্রহ নিয়ে দ্রুত কাজে লেগে পড়াই alacrity।",synonyms:["eagerness","enthusiasm","willingness"],antonyms:["reluctance","apathy","sluggishness"],examples:["The volunteers worked with great alacrity to complete the project.","She greeted every challenge with alacrity and optimism."]},
    {word:"Alleviate",pos:"verb",def:"To make pain or a problem less severe.",bangla:"কষ্ট বা সমস্যা লাঘব করা।",synonyms:["relieve","ease","mitigate"],antonyms:["worsen","aggravate","intensify"],examples:["The medicine helped alleviate her chronic back pain.","New programs were introduced to alleviate unemployment in the region."]},
    {word:"Aloof",pos:"adjective",def:"Not friendly or forthcoming; distant.",bangla:"দূরত্ব বজায় রাখা বা অমিশুক। যিনি সবার থেকে নিজেকে দূরে রাখেন, তিনি aloof।",synonyms:["distant","detached","reserved"],antonyms:["friendly","sociable","warm"],examples:["He remained aloof at parties, preferring to observe rather than participate.","Her aloof manner made it difficult to form close friendships."]}
  ],
  // SET 6
  [
    {word:"Altruistic",pos:"adjective",def:"Showing a selfless concern for the well-being of others.",bangla:"নিঃস্বার্থভাবে অন্যের ভালো চাওয়া। যিনি নিজের কথা না ভেবে অন্যের জন্য কাজ করেন, তিনি altruistic।",synonyms:["selfless","philanthropic","benevolent"],antonyms:["selfish","egotistic","greedy"],examples:["Her altruistic nature led her to donate half her salary to charity.","Altruistic behavior is rare but profoundly admired."]},
    {word:"Ambivalent",pos:"adjective",def:"Having mixed feelings or contradictory ideas about something.",bangla:"দ্বিধান্বিত। কোনো বিষয়ে একই সাথে দুটো বিপরীত অনুভূতি থাকলে সেটা ambivalent।",synonyms:["undecided","conflicted","uncertain"],antonyms:["certain","decided","resolute"],examples:["She felt ambivalent about accepting the prestigious but demanding job.","His ambivalent attitude toward the project confused his teammates."]},
    {word:"Ameliorate",pos:"verb",def:"To make something bad better.",bangla:"খারাপ অবস্থা উন্নত করা।",synonyms:["improve","better","enhance"],antonyms:["worsen","deteriorate","damage"],examples:["New policies were designed to ameliorate living conditions in slums.","Education can ameliorate many social problems."]},
    {word:"Anachronism",pos:"noun",def:"Something out of its proper historical time.",bangla:"কালানুপযোগী বিষয়। মধ্যযুগের ছবিতে মোবাইল ফোন দেখানো হলে সেটা anachronism।",synonyms:["relic","archaism","incongruity"],antonyms:["modernity","contemporaneity"],examples:["Using a quill pen in modern times would be a charming anachronism.","The film was criticized for its many historical anachronisms."]},
    {word:"Anarchy",pos:"noun",def:"A state of disorder due to absence of authority.",bangla:"অরাজকতা। যখন কোনো শাসন বা নিয়ম-শৃঙ্খলা থাকে না, তখন anarchy দেখা দেয়।",synonyms:["chaos","disorder","lawlessness"],antonyms:["order","government","discipline"],examples:["After the government collapsed, the country descended into anarchy.","Without leadership, the meeting devolved into anarchy."]}
  ],
  // SET 7
  [
    {word:"Anecdote",pos:"noun",def:"A short amusing or interesting story about a real incident.",bangla:"ছোট মজাদার বা আকর্ষণীয় গল্প। কোনো ব্যক্তির জীবনের মজার ঘটনার ছোট বিবরণই anecdote।",synonyms:["story","tale","account"],antonyms:["fiction","fabrication"],examples:["He entertained guests with anecdotes from his travels in Asia.","The professor began every lecture with a relevant anecdote."]},
    {word:"Animosity",pos:"noun",def:"Strong hostility or enmity.",bangla:"তীব্র বিদ্বেষ বা শত্রুতা। দুই ব্যক্তির মধ্যে গভীর ঘৃণাকে animosity বলে।",synonyms:["hostility","enmity","antagonism"],antonyms:["goodwill","friendship","harmony"],examples:["There was long-standing animosity between the two neighboring families.","Despite the animosity, both teams respected each other's skill."]},
    {word:"Anomalous",pos:"adjective",def:"Deviating from what is standard or expected.",bangla:"অস্বাভাবিক বা নিয়মবহির্ভূত। যা সাধারণ ধারা থেকে আলাদা তাই anomalous।",synonyms:["abnormal","irregular","atypical"],antonyms:["normal","typical","regular"],examples:["Scientists were puzzled by the anomalous readings from the experiment.","Her anomalous behavior prompted concern among her friends."]},
    {word:"Antipathy",pos:"noun",def:"A deep-seated feeling of dislike.",bangla:"গভীর অপছন্দ বা বিদ্বেষ।",synonyms:["aversion","hostility","dislike"],antonyms:["affinity","sympathy","attraction"],examples:["He had a natural antipathy toward dishonesty in any form.","Their mutual antipathy made working together nearly impossible."]},
    {word:"Apathy",pos:"noun",def:"Lack of interest, enthusiasm, or concern.",bangla:"উদাসীনতা ও আগ্রহের অভাব।",synonyms:["indifference","lethargy","detachment"],antonyms:["enthusiasm","passion","interest"],examples:["Public apathy toward the election resulted in record-low turnout.","Her apathy in the classroom frustrated her dedicated teacher."]}
  ],
  // SET 8
  [
    {word:"Appease",pos:"verb",def:"To pacify someone by acceding to their demands.",bangla:"দাবি পূরণ করে শান্ত করা।",synonyms:["pacify","placate","mollify"],antonyms:["provoke","antagonize","aggravate"],examples:["The manager appeased the angry client with a full refund.","Giving in to every demand only appeases temporarily."]},
    {word:"Apprehension",pos:"noun",def:"Anxiety or fear about a future event.",bangla:"ভবিষ্যৎ নিয়ে উদ্বেগ বা ভয়।",synonyms:["anxiety","dread","fear"],antonyms:["confidence","assurance","calmness"],examples:["She felt deep apprehension before her first public speech.","His apprehension about the surgery kept him awake all night."]},
    {word:"Archaic",pos:"adjective",def:"Very old or old-fashioned.",bangla:"অতি পুরনো বা সেকেলে। যে জিনিস বা ধারণা আর প্রচলিত নেই, তাকে archaic বলে।",synonyms:["ancient","obsolete","antiquated"],antonyms:["modern","contemporary","current"],examples:["The archaic legal system needed urgent reform.","He used archaic words that no one in the audience understood."]},
    {word:"Ardor",pos:"noun",def:"Great enthusiasm or passion.",bangla:"তীব্র উৎসাহ বা আবেগ। কোনো কাজে প্রবল আগ্রহ ও উদ্দীপনাকে ardor বলে।",synonyms:["passion","zeal","fervor"],antonyms:["apathy","indifference","coolness"],examples:["She pursued her art with extraordinary ardor and dedication.","His ardor for justice led him to become a human rights lawyer."]},
    {word:"Articulate",pos:"adjective",def:"Having or showing the ability to speak fluently and coherently.",bangla:"সুস্পষ্টভাবে কথা বলতে পারা। যিনি তার চিন্তাভাবনা পরিষ্কারভাবে প্রকাশ করতে পারেন, তিনি articulate।",synonyms:["eloquent","fluent","expressive"],antonyms:["inarticulate","mumbling","incoherent"],examples:["She was an articulate speaker who captivated every audience.","The articulate young lawyer impressed the court with his arguments."]}
  ],
  // SET 9
  [
    {word:"Ascetic",pos:"adjective",def:"Practicing strict self-discipline and abstaining from indulgence.",bangla:"তপস্বী জীবনযাপন। সুখ-আরাম ত্যাগ করে সংযমী জীবন যাপন করাকে ascetic বলে।",synonyms:["austere","abstemious","spartan"],antonyms:["indulgent","hedonistic","luxurious"],examples:["The ascetic monk lived on just water and rice.","His ascetic lifestyle was admired but rarely emulated."]},
    {word:"Assiduous",pos:"adjective",def:"Showing great care and perseverance.",bangla:"পরিশ্রমী ও অধ্যবসায়ী। যিনি অক্লান্ত পরিশ্রম করেন, তিনি assiduous।",synonyms:["diligent","industrious","persistent"],antonyms:["lazy","negligent","careless"],examples:["Her assiduous study habits earned her top marks every year.","The assiduous researcher worked late every night for months."]},
    {word:"Assuage",pos:"verb",def:"To make something unpleasant less intense.",bangla:"কষ্ট বা ব্যথা প্রশমিত করা।",synonyms:["relieve","ease","alleviate"],antonyms:["intensify","aggravate","worsen"],examples:["A heartfelt apology helped assuage her hurt feelings.","He tried to assuage his guilt by donating to charity."]},
    {word:"Astute",pos:"adjective",def:"Having a clever ability to assess situations.",bangla:"চালাক ও তীক্ষ্ণবুদ্ধি সম্পন্ন।",synonyms:["shrewd","perceptive","clever"],antonyms:["naive","obtuse","foolish"],examples:["The astute businesswoman spotted the market opportunity before anyone else.","His astute analysis of the data impressed the entire board."]},
    {word:"Atrophy",pos:"verb",def:"To gradually weaken and waste away.",bangla:"ধীরে ধীরে দুর্বল হয়ে যাওয়া। অব্যবহারে কোনো অঙ্গ বা দক্ষতা নষ্ট হয়ে গেলে তাকে atrophy বলে।",synonyms:["wither","deteriorate","degenerate"],antonyms:["grow","strengthen","flourish"],examples:["Muscles atrophy quickly without regular exercise.","His writing skills began to atrophy after years without practice."]}
  ],
  // SET 10
  [
    {word:"Audacious",pos:"adjective",def:"Showing willingness to take bold risks.",bangla:"সাহসী ও দুঃসাহসিক।",synonyms:["bold","daring","fearless"],antonyms:["timid","cowardly","cautious"],examples:["The audacious explorer attempted to cross the desert alone.","Her audacious business plan amazed even seasoned investors."]},
    {word:"Austere",pos:"adjective",def:"Severe and morally strict; without comfort or luxury.",bangla:"কঠোর ও সাদাসিধে।",synonyms:["stern","severe","spartan"],antonyms:["indulgent","luxurious","lenient"],examples:["The austere judge showed little sympathy for repeat offenders.","They lived an austere life in the remote mountain village."]},
    {word:"Avarice",pos:"noun",def:"Extreme greed for wealth.",bangla:"অতিরিক্ত ধন-লোভ। অসীম লালসাকে avarice বলে।",synonyms:["greed","covetousness","cupidity"],antonyms:["generosity","benevolence","altruism"],examples:["His avarice ultimately destroyed his closest friendships.","Corporate avarice led to widespread environmental damage."]},
    {word:"Aversion",pos:"noun",def:"A strong dislike or disinclination.",bangla:"তীব্র অপছন্দ। কোনো বিষয়ে গভীর বিরক্তি বা অনিচ্ছাকে aversion বলে।",synonyms:["dislike","repugnance","antipathy"],antonyms:["attraction","fondness","liking"],examples:["He had a deep aversion to dishonesty in any form.","Her aversion to spicy food made dining out a challenge."]},
