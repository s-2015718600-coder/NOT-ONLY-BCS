    {word:"Verbose",pos:"adjective",def:"Using more words than needed.",bangla:"অতিরিক্ত কথা বলে এমন।",synonyms:["wordy","long-winded","garrulous"],antonyms:["concise","brief","succinct"],examples:["The verbose report could have said the same thing in half the pages.","A verbose speaker loses the attention of the audience quickly."]},
    {word:"Vex",pos:"verb",def:"To make someone feel annoyed or worried.",bangla:"বিরক্ত বা উদ্বিগ্ন করা।",synonyms:["annoy","irritate","bother"],antonyms:["soothe","please","calm"],examples:["The constant interruptions vexed the speaker beyond measure.","It vexed him that no one acknowledged his contribution."]}
